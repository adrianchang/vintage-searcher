// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  googleId  String?  @unique
  email     String?  @unique
  language  String   @default("en")

  // Size profile (men's/unisex) — all optional; null means no size matching
  topSize        String? // "XS".."XXL"
  waistSize      Int?    // tag waist, inches
  pitToPitInches Float?  // optional refinement, overrides topSize

  createdAt DateTime @default(now())

  keywords   UserKeyword[]
  votes      Vote[]
  deliveries StoryDelivery[]
  archetypes UserArchetype[]
  engagement EngagementEvent[]
}

model UserKeyword {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  query      String
  percentage Float    // 0.0–1.0, must sum to 1.0 per user
  createdAt  DateTime @default(now())

  @@unique([userId, query])
}


// Full LLM evaluation results
model Evaluation {
  id             String   @id @default(cuid())
  url            String   @unique

  isAuthentic              Boolean
  itemIdentification       String   @default("")
  identificationConfidence Float    @default(0)
  estimatedEra             String?  // Nullable - Gemini may return null for non-vintage
  estimatedValue           Float?   // Nullable - Gemini may return null for non-vintage
  currentPrice   Float
  margin         Float?   // Nullable - can't calculate if estimatedValue is null
  confidence     Float
  reasoning      String
  redFlags       String   // JSON array
  references     String   // JSON array
  soldListings   String   @default("[]")  // JSON array
  priceScore     Float?
  imageUrl       String?

  // Size extraction (null on rows evaluated before size matching existed)
  garmentType    String? // top | outerwear | bottom | dress | footwear | accessory | other
  labeledSize    String?
  pitToPitInches Float?  // flat, inches
  waistInches    Float?  // tag waist, inches
  sizeConfidence Float?  // legacy (pre-resolution rows only) — no longer written
  sizeEvidence   String? // resolution: tag+measurement | tag | measurement | contradicted | none
  sizeRaw        String  @default("{}") // raw four-channel Gemini sizing block (pre-resolution) — audit trail

  isOpportunity  Boolean
  createdAt      DateTime @default(now())

  stories        Story[]
}

model Story {
  id                   String      @id @default(cuid())
  evaluationId         String
  evaluation           Evaluation  @relation(fields: [evaluationId], references: [id])
  language             String      @default("en")
  configId             String      @default("en-default")

  hook                 String
  mainStory            String
  styleGuide           String   @default("")

  storyScore           Float
  storyScoreReasoning  String
  combinedScore        Float

  createdAt            DateTime    @default(now())
  votes                Vote[]
  engagement           EngagementEvent[]

  @@unique([evaluationId, language, configId])
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id])
  direction String   // "up" or "down"
  createdAt DateTime @default(now())

  @@unique([userId, storyId])
}

model StoryDelivery {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  url    String
  sentAt DateTime @default(now())

  @@unique([userId, url])
}

model UserArchetype {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  archetypeId String   // slug: "americana", "ivy", etc.
  createdAt   DateTime @default(now())

  @@unique([userId, archetypeId])
}

// Implicit engagement signal: /go redirect clicks now; Resend webhook events
// (open/bounce/complaint) later — one table for everything the taste engine
// may eventually read alongside votes.
model EngagementEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  storyId   String?
  story     Story?   @relation(fields: [storyId], references: [id])
  type      String   // "click" (future: "open", "bounce", "complaint")
  createdAt DateTime @default(now())

  @@index([userId, type])
}

// Self-refreshing credentials (e.g. the Threads access token) — key/value,
// seeded from env vars, kept alive by the daily pipeline
model AppCredential {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

// Managed by connect-pg-simple (express-session), not by Prisma
model session {
  sid    String   @id @db.VarChar
  sess   Json
  expire DateTime @db.Timestamptz(6)

  @@index([expire])
}

