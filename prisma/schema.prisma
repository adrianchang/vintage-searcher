// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  googleId  String?  @unique
  email     String?  @unique
  language  String   @default("en")
  createdAt DateTime @default(now())
}


// Listings that passed the first filter (for iteration on filter rules)
model FilteredListing {
  id          String   @id @default(cuid())
  url         String   @unique
  platform    String
  title       String
  price       Float
  imageUrls   String   // JSON array of image URLs
  description String
  rawData     String   // JSON
  createdAt   DateTime @default(now())

  evaluation   Evaluation?
}

// Full LLM evaluation results
model Evaluation {
  id             String   @id @default(cuid())
  listingId      String   @unique
  listing        FilteredListing @relation(fields: [listingId], references: [id])

  isAuthentic              Boolean
  itemIdentification       String   @default("")
  identificationConfidence Float    @default(0)
  estimatedEra             String?  // Nullable - Gemini may return null for non-vintage
  estimatedValue           Float?   // Nullable - Gemini may return null for non-vintage
  currentPrice   Float
  margin         Float?   // Nullable - can't calculate if estimatedValue is null
  confidence     Float
  reasoning      String
  redFlags       String   // JSON array
  references     String   // JSON array
  soldListings   String   @default("[]")  // JSON array

  isOpportunity  Boolean
  createdAt      DateTime @default(now())

  stories        Story[]
}

model Story {
  id                   String      @id @default(cuid())
  evaluationId         String
  evaluation           Evaluation  @relation(fields: [evaluationId], references: [id])
  language             String      @default("en")

  hook                 String
  brandStory           String
  itemStory            String
  historicalContext    String
  marketContext        String

  storyScore           Float
  storyScoreReasoning  String
  combinedScore        Float

  createdAt            DateTime    @default(now())

  @@unique([evaluationId, language])
}

// Managed by connect-pg-simple (express-session), not by Prisma
model session {
  sid    String   @id @db.VarChar
  sess   Json
  expire DateTime @db.Timestamptz(6)

  @@index([expire])
}

